<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Fridge Friend — Live Monitor</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mqtt/5.3.4/mqtt.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;600&display=swap" rel="stylesheet" />
<style>
  :root {
    --bg:        #0b0f14;
    --surface:   #111720;
    --border:    #1e2a38;
    --text:      #c8d8e8;
    --muted:     #4a6070;
    --ice:       #7dd3fc;
    --green:     #22c55e;
    --red:       #ef4444;
    --amber:     #f59e0b;
    --mono:      'Space Mono', monospace;
    --sans:      'DM Sans', sans-serif;
    --radius:    12px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    min-height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr auto;
  }
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image:
      linear-gradient(rgba(125,211,252,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(125,211,252,.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none; z-index: 0;
  }
 
  /* ── HEADER ── */
  header {
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 32px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .logo { display: flex; align-items: center; gap: 12px; }
  .logo-icon { font-size: 28px; }
  .logo-text { font-family: var(--mono); font-size: 14px; font-weight: 700; color: var(--ice); letter-spacing: 2px; text-transform: uppercase; }
  .logo-sub  { font-size: 11px; color: var(--muted); letter-spacing: 1px; margin-top: 2px; }
 
  #conn-pill {
    display: flex; align-items: center; gap: 7px;
    padding: 6px 14px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--mono); font-size: 11px; color: var(--muted);
    transition: all .3s;
  }
  #conn-pill.connected { border-color: var(--green); color: var(--green); }
  #conn-pill.error     { border-color: var(--red);   color: var(--red); }
  .pill-dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; }
  #conn-pill.connected .pill-dot { animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
 
  /* ── MAIN ── */
  main {
    position: relative; z-index: 1;
    display: grid;
    grid-template-columns: 1fr 320px;
    grid-template-rows: auto 1fr;
    gap: 20px;
    padding: 24px 32px;
    max-width: 1200px;
    margin: 0 auto; width: 100%;
  }
 
  /* ── STATUS HERO ── */
  .status-hero {
    grid-column: 1 / -1;
    display: flex; align-items: center; gap: 28px;
    padding: 28px 32px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    position: relative; overflow: hidden;
    transition: border-color .5s;
  }
  .status-hero::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 40% 50%, var(--glow, transparent) 0%, transparent 60%);
    opacity: .12; pointer-events: none; transition: background .5s;
  }
  .status-hero.state-green { --glow: var(--green); border-color: #166534; }
  .status-hero.state-red   { --glow: var(--red);   border-color: #7f1d1d; }
  .status-hero.state-blink { --glow: var(--amber);  border-color: #78350f; }
 
  .led-orb {
    flex-shrink: 0; width: 64px; height: 64px; border-radius: 50%;
    background: #1a2030; border: 3px solid var(--border);
    box-shadow: inset 0 2px 4px rgba(0,0,0,.5);
    transition: background .4s, box-shadow .4s, border-color .4s;
    position: relative;
  }
  .led-orb.green {
    background: var(--green); border-color: #4ade80;
    box-shadow: 0 0 24px var(--green), 0 0 60px rgba(34,197,94,.4), inset 0 1px 3px rgba(255,255,255,.3);
  }
  .led-orb.red {
    background: var(--red); border-color: #f87171;
    box-shadow: 0 0 24px var(--red), 0 0 60px rgba(239,68,68,.4), inset 0 1px 3px rgba(255,255,255,.3);
  }
  .led-orb.blink { animation: blink-anim .6s ease-in-out infinite; border-color: #fbbf24; }
  @keyframes blink-anim {
    0%,100% { background:var(--red); box-shadow:0 0 24px var(--red),0 0 60px rgba(239,68,68,.5),inset 0 1px 3px rgba(255,255,255,.3); }
    50%      { background:#3a0a0a; box-shadow:none; }
  }
  .led-orb::after {
    content:''; position:absolute; top:12%; left:20%;
    width:35%; height:35%; background:rgba(255,255,255,.25); border-radius:50%; filter:blur(3px);
  }
 
  .status-text { flex: 1; }
  .status-label { font-family:var(--mono); font-size:11px; letter-spacing:2px; color:var(--muted); text-transform:uppercase; margin-bottom:6px; }
  #status-headline { font-family:var(--mono); font-size:26px; font-weight:700; line-height:1.1; transition:color .4s; }
  #status-detail   { font-size:13px; color:var(--muted); margin-top:6px; }
  .status-time { font-family:var(--mono); font-size:11px; color:var(--muted); text-align:right; }
  #last-update { display:block; margin-top:4px; }
 
  /* ── CARDS ── */
  .cards { display:flex; flex-direction:column; gap:16px; }
  .card {
    background:var(--surface); border:1px solid var(--border);
    border-radius:var(--radius); padding:20px 22px;
    display:flex; flex-direction:column; gap:8px;
  }
  .card-header { display:flex; align-items:center; justify-content:space-between; }
  .card-icon   { font-size:18px; }
  .card-label  { font-family:var(--mono); font-size:10px; letter-spacing:2px; color:var(--muted); text-transform:uppercase; }
  .card-value  { font-family:var(--mono); font-size:36px; font-weight:700; color:var(--ice); line-height:1; }
  .card-value .unit { font-size:14px; color:var(--muted); margin-left:4px; }
  .card-sub    { font-size:12px; color:var(--muted); }
 
  .temp-bar-track { height:4px; background:var(--border); border-radius:2px; margin-top:4px; overflow:hidden; }
  .temp-bar-fill  { height:100%; border-radius:2px; background:var(--green); transition:width .4s ease, background .4s; }
 
  .badge { display:inline-flex; align-items:center; gap:5px; padding:3px 10px; border-radius:999px; font-family:var(--mono); font-size:11px; border:1px solid; }
  .badge.on  { background:rgba(251,191,36,.08); color:var(--amber); border-color:rgba(251,191,36,.3); }
  .badge.off { background:rgba(74,96,112,.08);  color:var(--muted); border-color:var(--border); }
 
  /* ── LOG PANEL ── */
  .log-panel {
    background:var(--surface); border:1px solid var(--border);
    border-radius:var(--radius); display:flex; flex-direction:column; overflow:hidden;
  }
  .log-header { padding:16px 20px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
  .log-title  { font-family:var(--mono); font-size:11px; letter-spacing:2px; color:var(--ice); text-transform:uppercase; }
  #log-count  { font-family:var(--mono); font-size:10px; background:var(--border); border-radius:999px; padding:2px 8px; color:var(--muted); }
  #log-list   { flex:1; overflow-y:auto; padding:8px 0; max-height:340px; }
  #log-list::-webkit-scrollbar { width:4px; }
  #log-list::-webkit-scrollbar-thumb { background:var(--border); border-radius:2px; }
  .log-entry  { display:flex; align-items:flex-start; gap:12px; padding:8px 20px; border-bottom:1px solid rgba(30,42,56,.5); animation:slide-in .25s ease; }
  @keyframes slide-in { from{opacity:0;transform:translateX(-8px)} to{opacity:1;transform:translateX(0)} }
  .log-time   { font-family:var(--mono); font-size:10px; color:var(--muted); flex-shrink:0; padding-top:1px; }
  .log-msg    { font-size:12px; color:var(--text); line-height:1.4; }
  .log-empty  { padding:32px 20px; text-align:center; color:var(--muted); font-size:12px; }
 
  /* ── RAW PANEL ── */
  .raw-panel {
    grid-column:1/-1; background:var(--surface); border:1px solid var(--border);
    border-radius:var(--radius); padding:14px 20px;
    display:flex; align-items:center; gap:8px;
    font-family:var(--mono); font-size:12px; color:var(--muted); flex-wrap:wrap;
  }
  .raw-label { color:var(--ice); margin-right:2px; }
  #raw-output { color:var(--text); }
 
  /* ── WAITING OVERLAY ── */
  #waiting {
    grid-column:1/-1; display:flex; flex-direction:column;
    align-items:center; justify-content:center; gap:12px;
    padding:60px; text-align:center;
  }
  #waiting .w-icon { font-size:48px; animation:spin 3s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  #waiting .w-title { font-family:var(--mono); font-size:14px; color:var(--ice); letter-spacing:2px; }
  #waiting .w-sub   { font-size:13px; color:var(--muted); }
 
  footer {
    position:relative; z-index:1; text-align:center; padding:14px;
    border-top:1px solid var(--border);
    font-family:var(--mono); font-size:10px; color:var(--muted); letter-spacing:1px;
  }
 
  @media (max-width:768px) {
    main { grid-template-columns:1fr; padding:16px; }
    .status-hero { flex-direction:column; text-align:center; }
  }
</style>
</head>
<body>
 
<header>
  <div class="logo">
    <span class="logo-icon">🧊</span>
    <div>
      <div class="logo-text">Fridge Friend</div>
      <div class="logo-sub">Live Monitor · ThingSpeak MQTT</div>
    </div>
  </div>
  <div id="conn-pill">
    <span class="pill-dot"></span>
    <span id="conn-label">Connecting…</span>
  </div>
</header>
 
<main>
  <!-- Shown until first message arrives -->
  <div id="waiting">
    <div class="w-icon">📡</div>
    <div class="w-title">Waiting for data</div>
    <div class="w-sub">Connected to ThingSpeak — waiting for the Pi to publish its first reading…</div>
  </div>
 
  <!-- Hidden until data arrives -->
  <div class="status-hero" id="status-hero" style="display:none">
    <div class="led-orb" id="led-orb"></div>
    <div class="status-text">
      <div class="status-label">System Status</div>
      <div id="status-headline">—</div>
      <div id="status-detail">—</div>
    </div>
    <div class="status-time">
      <div>Last update</div>
      <span id="last-update">—</span>
    </div>
  </div>
 
  <div class="cards" id="cards" style="display:none">
    <div class="card">
      <div class="card-header"><span class="card-icon">🌡️</span><span class="card-label">Temperature</span></div>
      <div class="card-value"><span id="val-temp">—</span><span class="unit">°F</span></div>
      <div class="temp-bar-track"><div class="temp-bar-fill" id="temp-bar" style="width:0%"></div></div>
      <div class="card-sub" id="temp-note">Ideal range: 34 – 60 °F</div>
    </div>
    <div class="card">
      <div class="card-header"><span class="card-icon">📡</span><span class="card-label">Door Distance</span></div>
      <div class="card-value"><span id="val-dist">—</span><span class="unit">cm</span></div>
      <div class="card-sub" id="dist-note">Closed = 0.5 – 5.0 cm from sensor</div>
    </div>
    <div class="card">
      <div class="card-header"><span class="card-icon">💡</span><span class="card-label">Interior Light</span></div>
      <div style="display:flex;align-items:center;gap:12px;margin-top:4px">
        <span class="badge off" id="light-badge"><span id="light-label">OFF</span></span>
        <span class="card-sub" id="light-note">Should be off when sealed</span>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><span class="card-icon">🚪</span><span class="card-label">Door State</span></div>
      <div class="card-value" style="font-size:22px" id="val-door">—</div>
    </div>
  </div>
 
  <div class="log-panel" id="log-panel" style="display:none">
    <div class="log-header">
      <span class="log-title">Event Log</span>
      <span id="log-count">0 events</span>
    </div>
    <div id="log-list"><div class="log-empty">No events yet…</div></div>
  </div>
 
  <div class="raw-panel" id="raw-panel" style="display:none">
    <span class="raw-label">RAW →</span>
    <span id="raw-output">—</span>
  </div>
</main>
 
<footer>FRIDGE FRIEND · MAE4194/6194 &amp; IoT · Claudia S. Rodriguez Chevere</footer>
 
<script>
// THINGSPEAK CONFIG 
const CHANNEL_ID   = "3348218";
const READ_API_KEY = "4PS77NPUJ87EYGMX";
const POLL_MS      = 15000;   // 15 seconds (ThingSpeak free tier limit)

// STATUS CODE MAP
const STATUS = {
  0: { label:"All Good",   detail:"Door sealed · Temp in range · Light off", led:"green", heroClass:"state-green", color:"var(--green)", door:"✅ Properly Closed" },
  1: { label:"Door Open",  detail:"Light on and door away from sensor",      led:"red",   heroClass:"state-red",   color:"var(--red)",   door:"🚪 Open" },
  2: { label:"Bad Seal",   detail:"Door closed but interior light still on", led:"red",   heroClass:"state-red",   color:"var(--red)",   door:"⚠️ Incorrectly Closed" },
  3: { label:"TEMP ALERT", detail:"Temperature exceeds 60°F threshold",      led:"blink", heroClass:"state-blink", color:"var(--amber)", door:"🌡️ Check Temp" },
  4: { label:"Uncertain",  detail:"Sensor readings are ambiguous",           led:"red",   heroClass:"state-red",   color:"var(--red)",   door:"❓ Unknown" },
};

// ── DOM REFS ──────────────────────────────────────────────────────
const pill      = document.getElementById('conn-pill');
const connLabel = document.getElementById('conn-label');
const waiting   = document.getElementById('waiting');
const hero      = document.getElementById('status-hero');
const ledOrb    = document.getElementById('led-orb');
const headline  = document.getElementById('status-headline');
const detail    = document.getElementById('status-detail');
const lastUpd   = document.getElementById('last-update');
const logList   = document.getElementById('log-list');
const logCount  = document.getElementById('log-count');

let eventLog  = [];
let prevStatus = null;
let firstData  = false;

function revealUI() {
  if (firstData) return;
  firstData = true;
  waiting.style.display = 'none';
  ['status-hero','cards','log-panel','raw-panel'].forEach(id => {
    document.getElementById(id).style.display = '';
  });
}

function applyData(tempF, distCm, lightOn, statusCode) {
  revealUI();
  const cfg = STATUS[statusCode] ?? STATUS[4];
  const now = new Date().toLocaleTimeString();
  lastUpd.textContent = now;

  hero.className = `status-hero ${cfg.heroClass}`;
  ledOrb.className = `led-orb ${cfg.led}`;
  headline.textContent = cfg.label;
  headline.style.color = cfg.color;
  detail.textContent   = cfg.detail;

  document.getElementById('val-temp').textContent = tempF.toFixed(1);
  const pct = Math.max(0, Math.min(100, ((Math.max(28, Math.min(50, tempF)) - 28) / 22) * 100));
  const bar  = document.getElementById('temp-bar');
  bar.style.width = pct + '%';
  const note = document.getElementById('temp-note');
  if (tempF > 60)      { bar.style.background='var(--red)';   note.textContent='⚠️ Above safe range (34–60°F)'; note.style.color='var(--red)'; }
  else if (tempF < 34) { bar.style.background='var(--ice)';   note.textContent='❄️ Below ideal range (34–60°F)'; note.style.color='var(--ice)'; }
  else                 { bar.style.background='var(--green)'; note.textContent='✅ Within safe range (34–60°F)'; note.style.color='var(--green)'; }

  document.getElementById('val-dist').textContent = distCm.toFixed(2);
  const closed = distCm >= 0 && distCm <= 5.0;
  const dn = document.getElementById('dist-note');
  dn.textContent = closed ? '✅ Within closed range (0–5.0 cm)' : distCm > 5.0 ? '🚪 Door is open / ajar' : '⚠️ Too close — check sensor';
  dn.style.color = closed ? 'var(--green)' : distCm > 5.0 ? 'var(--red)' : 'var(--amber)';

  const badge = document.getElementById('light-badge');
  const lbl   = document.getElementById('light-label');
  const ln    = document.getElementById('light-note');
  if (lightOn) { badge.className='badge on';  lbl.textContent='ON';  ln.textContent='⚠️ Light detected inside'; ln.style.color='var(--amber)'; }
  else         { badge.className='badge of'; lbl.textContent='OFF'; ln.textContent='✅ No light — door sealed'; ln.style.color='var(--green)'; }

  document.getElementById('val-door').textContent = cfg.door;
  document.getElementById('raw-output').textContent =
    `temp:${tempF.toFixed(2)}°F  dist:${distCm.toFixed(2)}cm  light:${lightOn}  status:${statusCode}(${cfg.label})`;

  if (statusCode !== prevStatus) {
    eventLog.unshift({ time: now, msg: `${cfg.door} — ${cfg.detail}` });
    if (eventLog.length > 50) eventLog.pop();
    prevStatus = statusCode;
    renderLog();
  }
}

function renderLog() {
  logCount.textContent = `${eventLog.length} event${eventLog.length !== 1 ? 's' : ''}`;
  logList.innerHTML = eventLog.length
    ? eventLog.map(e => `<div class="log-entry"><span class="log-time">${e.time}</span><span class="log-msg">${e.msg}</span></div>`).join('')
    : '<div class="log-empty">No events yet…</div>';
}

// ── POLL THINGSPEAK ───────────────────────────────────────────────
async function poll() {
  const url = `https://api.thingspeak.com/channels/${CHANNEL_ID}/feeds/last.json?api_key=${READ_API_KEY}`;
  try {
    const res  = await fetch(url);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();

    const tempF      = parseFloat(data.field1);
    const distCm     = parseFloat(data.field2);
    const lightOn    = parseInt(data.field3) === 1;
    const statusCode = parseInt(data.field4);

    if (!isNaN(tempF) && !isNaN(statusCode)) {
      pill.className = 'connected';
      connLabel.textContent = 'Live';
      applyData(tempF, distCm, lightOn, statusCode);
    }
  } catch(e) {
    pill.className = 'error';
    connLabel.textContent = 'Error';
    console.error('Poll error:', e);
  }
}

poll();
setInterval(poll, POLL_MS);
</script>
</body>
</html>
